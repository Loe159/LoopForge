{
  "name": "documentation",
  "version": 1,
  "description": "Pack for documentation-heavy repositories and docs-only tasks.",
  "priority": 5,
  "detection": {
    "dirs_any": ["docs"],
    "files_any": ["mkdocs.yml", "mkdocs.yaml", "docs/conf.py"]
  },
  "skills": ["documentation-editing"],
  "skill_file": "SKILL.md",
  "checks_file": "checks.json",
  "protected_paths_file": "protected-paths.json",
  "memory_rules_file": "memory-rules.md",
  "memory": {
    "auto_promote": []
  }
}
